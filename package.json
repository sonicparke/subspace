{
  "name": "subspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/subspace --define BUILD_VERSION=\\\"$npm_package_version\\\" && pnpm run install:bin",
    "install:bin": "install -m 755 dist/subspace /opt/homebrew/bin/subspace",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@oscli-dev/oscli": "^0.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest"
  }
}
